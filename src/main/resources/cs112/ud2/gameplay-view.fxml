<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs112.ud2.controller.GameplayController"
      spacing="15"
      alignment="CENTER"
      prefWidth="500"
      styleClass="gameplay-view">

    <padding>
        <Insets top="30" bottom="30" left="30" right="30"/>
    </padding>

    <Label text="Gameplay / Debug View" styleClass="title-label" />

    <HBox spacing="20">
        <!-- Left Column -->
        <VBox spacing="12">
            <Label text="Fleet Management" styleClass="section-label"/>
        </VBox>

        <!-- Right Column -->
        <VBox spacing="12">
            <Label text="Ship Actions" styleClass="section-label"/>
        </VBox>
    </HBox>

    <HBox spacing="20">
        <VBox spacing="12">
            <Label text="Resources" styleClass="section-label"/>
            <Button text="+100 Minerals" onAction="#addMinerals" prefWidth="180"/>
            <Button text="+100 Salvage" onAction="#addSalvage" prefWidth="180"/>
            <Button text="+100 Energy" onAction="#addEnergy" prefWidth="180"/>
            <Button text="+200 Credits" onAction="#addCredits" prefWidth="180"/>
        </VBox>

        <VBox spacing="12">
            <Label text=" " styleClass="section-label"/>
            <Button text="-50 Minerals" onAction="#subtractMinerals" prefWidth="180"/>
            <Button text="-50 Salvage" onAction="#subtractSalvage" prefWidth="180"/>
            <Button text="-50 Energy" onAction="#subtractEnergy" prefWidth="180"/>
            <Button text="-50 Credits" onAction="#subtractCredits" prefWidth="180"/>
        </VBox>
    </HBox>

    <Separator/>

</VBox>